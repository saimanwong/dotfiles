{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "external_directory": {
      "~/.config/opencode/commands": "allow",
      "~/.config/opencode/commands/**": "allow",
      "~/.config/opencode/skills": "allow",
      "~/.config/opencode/skills/**": "allow",
      "~/.claude/commands": "allow",
      "~/.claude/commands/**": "allow",
      "~/.claude/skills": "allow",
      "~/.claude/skills/**": "allow",
      "~/Documents/docs/**": "allow",
      "/tmp": "allow",
      "/private/tmp": "allow"
    }
  },
  "mcp": {
    "Linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/sse",
      "enabled": true
    },
    "miro": {
      "type": "remote",
      "url": "https://mcp.miro.com/",
      "enabled": true,
      "timeout": 15000
    }
  }
}
